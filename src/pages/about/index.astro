---
import type { MarkdownHeading } from 'astro'
import { Button, Collapse, Spoiler, Timeline } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'
import Substats from '@/components/about/Substats.astro'
import ToolSection from '@/components/about/ToolSection.astro'
import SkillSection from '@/components/about/SkillSection.astro'

const headings: MarkdownHeading[] = [
  { depth: 2, slug: 'education', text: 'Education' },
  { depth: 2, slug: 'skills', text: 'Skills' },
  { depth: 2, slug: 'honors-and-awards', text: 'Honors and Awards' },
  // { depth: 2, slug: 'gossips', text: 'Gossips' },
  // { depth: 2, slug: 'about-blog', text: 'About Blog' }
]
---

<PageLayout title='About' {headings} comment>
  <p>
    I'm <strong>Cheng-Ju (Sam) Shih</strong>, also known as <strong>Honor</strong> (handle: <strong>honor2016tw</strong>), an undergraduate student majoring <strong>Electrical Engineering</strong>, with double major in <strong>Computer Science</strong> and <strong>Program of finance</strong> at National Taiwan Normal University.
  </p>

  <p>
    My interests mainly lie in the fields of <strong>Cybersecurity</strong>, <strong>Embedded Systems</strong>, <strong>Computer Vision</strong>, <strong>Financial Technology</strong> and <strong>Full Stack Development</strong>.
  </p>

  <p>
    I enjoy participating in various competitions like: <strong>CTF(Capture The Flag, Competition for Cybersecurity)</strong>, <strong>hackathons</strong>
  </p>

  {/* education */}
  <h2 id='education'>Education</h2>
  <Collapse title='National Taiwan Normal University (2023 - Present)'>
    <ul>
